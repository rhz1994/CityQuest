# Copy to .env first:
#   cp .env.example .env

# Docker (used by docker-compose.yaml)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=cityquest
MYSQL_USER=cityquest
MYSQL_PASSWORD=password

# Backend app (used by Node/Express)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=cityquest
PORT=5000

# Auth (backend-issued JWT)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
